{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/app/**/{page,layout,loading,error}.tsx",
    "src/i18n/request.ts",
    "src/middleware.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["src/components/pages/ui-kit/index.tsx"],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "tailwindcss",
    "prettier-plugin-tailwindcss",
    "@trivago/prettier-plugin-sort-imports",
    "eslint-config-next",
    "typescript-eslint",
    "@eslint/js",
    "globals",
    "eslint-plugin-react",
    "shadcn",
    "tw-animate-css",
    "@commitlint/config-conventional"
  ],
  "ignoreBinaries": ["prettier"]
}
