{
  "useTabs": false,
  "tabWidth": 2,
  "arrowParens": "always",
  "singleQuote": true,
  "semi": true,
  "trailingComma": "all",
  "singleAttributePerLine": true,
  "bracketSpacing": true,
  "plugins": [
    "@trivago/prettier-plugin-sort-imports",
    "prettier-plugin-tailwindcss"
  ],
  "importOrder": [
    "^react(.*)$",
    "^next(.*)$",
    "<THIRD_PARTY_MODULES>",
    "^@/components/layout/(.*)$",
    "^@/components/pages/(.*)$",
    "^@/components/ui/(.*)$",
    "lucide-react",
    "^@/lib/(.*)$",
    "^@/hooks/(.*)$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}
